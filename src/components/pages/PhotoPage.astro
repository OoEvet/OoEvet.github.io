---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { copy } from '../../lib/site';
import { getPhotos } from '../../lib/photos';

const t = copy;
const photos = await getPhotos();
const placeholders = t.photo.slots.slice(0, Math.max(0, 4 - photos.length));
---

<BaseLayout section="photo" title={t.photo.title} description={t.photo.subtitle}>
  <section class="page">
    <header class="page-heading">
      <h1>{t.photo.title}</h1>
      <p>{t.photo.subtitle}</p>
    </header>
    <p class="notice">{t.photo.notice}</p>
    <div class="photo-grid">
      {photos.map((photo) => (
        <article class="photo-slot photo-entry">
          <div class="photo-frame">
            <Image
              src={photo.image}
              alt={photo.alt}
              width={900}
              quality={84}
              loading="lazy"
            />
          </div>
          <div class="photo-caption">
            {photo.date ? <time datetime={photo.date}>{photo.date}</time> : <span>Undated</span>}
            {photo.location && <span>{photo.location}</span>}
          </div>
          {(photo.camera || photo.lens || photo.settings.length > 0) && (
            <div class="photo-exif" aria-label="Camera and exposure information">
              {(photo.camera || photo.lens) && (
                <p class="photo-gear">
                  {photo.camera && <span>{photo.camera}</span>}
                  {photo.camera && photo.lens && <span aria-hidden="true"> · </span>}
                  {photo.lens && <span>{photo.lens}</span>}
                </p>
              )}
              {photo.settings.length > 0 && (
                <p class="photo-settings">
                  {photo.settings.map((setting, index) => (
                    <><span>{setting}</span>{index < photo.settings.length - 1 && <span aria-hidden="true"> · </span>}</>
                  ))}
                </p>
              )}
            </div>
          )}
          {photo.caption && <p class="photo-note">{photo.caption}</p>}
        </article>
      ))}
      {placeholders.map((slot, index) => (
        <article class="photo-slot">
          <div class="photo-frame" aria-label={slot}><span>{String(photos.length + index + 1).padStart(2, '0')}</span></div>
          <div class="photo-caption"><span>{slot}</span><span>—</span></div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
