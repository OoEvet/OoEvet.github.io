---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { copy } from '../../lib/site';
import { getPhotos } from '../../lib/photos';

const t = copy;
const photos = await getPhotos();
const placeholders = t.photo.slots.slice(0, Math.max(0, 4 - photos.length));
---

<BaseLayout section="photo" title={t.photo.title} description={t.photo.subtitle}>
  <section class="page">
    <header class="page-heading">
      <h1>{t.photo.title}</h1>
      <p>{t.photo.subtitle}</p>
    </header>
    <p class="notice">{t.photo.notice}</p>
    <div class="photo-grid">
      {photos.map((photo, index) => (
        <article class="photo-slot photo-entry">
          <div class="photo-frame">
            <button
              class="photo-open"
              type="button"
              data-lightbox-open={`photo-lightbox-${index}`}
              aria-label={`View larger: ${photo.alt}`}
            >
              <Image
                src={photo.image}
                alt={photo.alt}
                width={900}
                quality={84}
                loading="lazy"
              />
            </button>
          </div>
          <div class="photo-caption">
            {photo.date ? <time datetime={photo.date}>{photo.date}</time> : <span>Undated</span>}
            {photo.location && <span>{photo.location}</span>}
          </div>
          {(photo.camera || photo.lens || photo.settings.length > 0) && (
            <div class="photo-exif" aria-label="Camera and exposure information">
              {(photo.camera || photo.lens) && (
                <p class="photo-gear">
                  {photo.camera && <span>{photo.camera}</span>}
                  {photo.camera && photo.lens && <span aria-hidden="true"> · </span>}
                  {photo.lens && <span>{photo.lens}</span>}
                </p>
              )}
              {photo.settings.length > 0 && (
                <p class="photo-settings">
                  {photo.settings.map((setting, index) => (
                    <><span>{setting}</span>{index < photo.settings.length - 1 && <span aria-hidden="true"> · </span>}</>
                  ))}
                </p>
              )}
            </div>
          )}
          {photo.caption && <p class="photo-note">{photo.caption}</p>}
        </article>
      ))}
      {placeholders.map((slot, index) => (
        <article class="photo-slot">
          <div class="photo-frame" aria-label={slot}><span>{String(photos.length + index + 1).padStart(2, '0')}</span></div>
          <div class="photo-caption"><span>{slot}</span><span>—</span></div>
        </article>
      ))}
    </div>

    {photos.map((photo, index) => (
      <dialog class="photo-lightbox" id={`photo-lightbox-${index}`} aria-label={photo.alt}>
        <div class="photo-lightbox-panel">
          <button class="photo-lightbox-close" type="button" data-lightbox-close aria-label="Close image">
            <span aria-hidden="true">×</span>
          </button>
          <figure>
            <Image
              src={photo.image}
              alt={photo.alt}
              width={1800}
              quality={90}
              loading="lazy"
            />
            <figcaption>
              <div class="photo-lightbox-heading">
                {photo.date ? <time datetime={photo.date}>{photo.date}</time> : <span>Undated</span>}
                {photo.location && <span>{photo.location}</span>}
              </div>
              {(photo.camera || photo.lens) && (
                <p>
                  {photo.camera && <span>{photo.camera}</span>}
                  {photo.camera && photo.lens && <span aria-hidden="true"> · </span>}
                  {photo.lens && <span>{photo.lens}</span>}
                </p>
              )}
              {photo.settings.length > 0 && (
                <p class="photo-lightbox-settings">
                  {photo.settings.map((setting, settingIndex) => (
                    <><span>{setting}</span>{settingIndex < photo.settings.length - 1 && <span aria-hidden="true"> · </span>}</>
                  ))}
                </p>
              )}
              {photo.caption && <p>{photo.caption}</p>}
            </figcaption>
          </figure>
        </div>
      </dialog>
    ))}
  </section>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-lightbox-open]').forEach((button) => {
    button.addEventListener('click', () => {
      const dialogId = button.dataset.lightboxOpen;
      const dialog = dialogId ? document.getElementById(dialogId) : null;

      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
      }
    });
  });

  document.querySelectorAll<HTMLDialogElement>('.photo-lightbox').forEach((dialog) => {
    dialog.querySelector<HTMLButtonElement>('[data-lightbox-close]')?.addEventListener('click', () => {
      dialog.close();
    });

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });
  });
</script>
