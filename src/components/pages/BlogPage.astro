---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { copy } from '../../lib/site';
const t = copy;
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const dateLocale = 'en-US';
---

<BaseLayout section="blog" title={t.blog.title} description={t.blog.subtitle}>
  <section class="page">
    <header class="page-heading">
      <h1>{t.blog.title}</h1>
      <p>{t.blog.subtitle}</p>
    </header>
    {posts.length === 0 ? <p>{t.blog.empty}</p> : (
      <ol class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.data.path}/`}>
              <time class="meta" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString(dateLocale, { year: 'numeric', month: '2-digit', day: '2-digit' })}
              </time>
              <span>
                <span class="post-title">{post.data.title}</span>
                <span class="post-description">{post.data.description}</span>
              </span>
              <span aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ol>
    )}
  </section>
</BaseLayout>
